<?xml version="1.0" encoding="UTF-8"?>
<theme>
<formatVersion>7</formatVersion>
<!-- Карусель + фанарт -->
	<customView name="Carousel + Fanart" inherits="gamecarousel" displayName="${carouselFanartViewName}">
	<!-- Disable gamecarousel view -->
	<image name="thumbnail-art">
		<visible>false</visible>
	</image>
	<image name="gamelist-background">
		<visible>false</visible>
	</image>
	<stackpanel name="container-icons">
		<visible>false</visible>
	</stackpanel>
	<container name="container-gamedata">
		<visible>false</visible>
	</container>
	<container name="container-gamedata2">
		<visible>false</visible>
	</container>
	<stackpanel name="container-gamedata3">
		<visible>false</visible>
	</stackpanel>
	<stackpanel name="container-flags">
		<visible>false</visible>
	</stackpanel>

	<!-- Панель с иконками игроков, ачивок, руля и т.д.-->
		<stackpanel name="container-icons2">
			<separator>0.015</separator>
			<pos>0.065 0.23</pos>
			<size>0.47 0.032</size>
			<size if="${screen.ratio} == '4/3'">0.47 0.036</size>
			<orientation>horizontal</orientation>
			<zIndex>150</zIndex>
			
			<!-- Год выпуска -->
			<text name="game-releaseyear">
				<fontSize>0.026</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.031</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:releaseyear}</text>
				<color>4CDF6C</color>
				<padding>4 0 4 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>!empty({game:releaseyear})</visible>
			</text>
			
			<image name="icons-favorite">
				<visible>{game:favorite}</visible>
				<path>${themePath}/_inc/images/heart.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			<text name="icons-players">
				<fontPath>${fontPlayers}</fontPath>
				<text>{game:playerCount}</text>
				<alignment>center</alignment>
				<fontSize>0.03</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.036</fontSize>
				<color>D0D0D0D0</color>
			</text>
			
			<!-- Флаги / Flags -->
			<image name="flag-region">
				<path>${themePath}/_inc/images/flags/{game:region}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>{game:region} != {game:lang} &amp;&amp; !contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-force-world">
				<path>${themePath}/_inc/images/flags/wr.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-lang">
				<path>${themePath}/_inc/images/flags/{game:lang}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>!contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</image>
			<text name="gamedata-lang">
				<fontSize>0.019</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:lang}.upper()</text>
				<color>FFFFFF</color>
				<padding>4 0 4 0</padding>
				<singleLineScroll>true</singleLineScroll>
				<autoScrollDelay>0</autoScrollDelay>
				<y>0.02</y>
				<visible>contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</text>
			
			<image name="icons-manual">
				<visible>{game:hasManual}</visible>
				<path>${themePath}/_inc/images/book.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-cheevos">
				<visible>{game:cheevos}</visible>
				<path>${themePath}/_inc/icons/Contest.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			<image name="icons-save">
				<visible>{game:hasSaveState}</visible>
				<path>${themePath}/_inc/icons/SaveState.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-wheel">
				<visible>{game:wheelGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/wheel.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-gun">
				<visible>{game:gunGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/gun.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-padtokey">
				<visible>{game:hasKeyboardMapping}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/padtokey.png</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-hidden">
				<visible>{game:hidden}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/hidden.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			<image name="icons-kid">
				<visible>{game:kidGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/kid.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
		</stackpanel>

		<!-- Панель с рейтингом и разработчиком -->
		<stackpanel name="game-data">
			<separator>0.015</separator>
			<pos>0.065 0.43</pos>
			<size>0.47 0.032</size>
			<size if="${screen.ratio} == '4/3'">0.47 0.036</size>
			<orientation>horizontal</orientation>
			<zIndex>150</zIndex>
			
			<!-- Рейтинг -->
			<text name="gamedata-stars">
				<fontSize>0.028</fontSize>
				<text>{game:stars}</text>
				<color>D0D0D0D0</color>
				<visible>!empty({game:stars})</visible>
			</text>
			
			<!-- Разработчик -->
			<text>
				<pos>0.08 0</pos> <!-- Сдвигает текст правее иконки -->
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.027</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:developer}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>!empty({game:developer})</visible>
			</text>
		</stackpanel>

		<image name="md_cartridge">
			<visible>true</visible>
			<pos>0.785 0.71</pos>
			<maxSize>0.215 0.35</maxSize>
			<pos>0.795 0.71</pos>
			<origin if="${screen.ratio} == '4/3'">0.4 0.4</origin>
			<maxSize if="${screen.ratio} == '4/3'">0.245 0.45</maxSize>
		</image>
		
		<image name="logo">
			<visible>false</visible>
		</image>
		<!-- Logo anim bzz -->
		<image name="logo1" extra="true">
			<pos>0.5 0.12</pos> <!-- Должно совпадать с logo -->
			<maxSize>0.240 0.126</maxSize> <!-- Должно совпадать с logo -->
			<opacity>0</opacity>
			<zIndex>150</zIndex>
			<storyboard event="activate"/>
			<storyboard>
				<animation property="opacity" from="0.75" to="0" begin="995" duration="4000" mode="EaseOut"/>
				<animation property="scale" from="1.05" to="1.4" begin="995" duration="4000" mode="EaseOut"/>
				<animation property="color" from="FFAAAA" to="FF7777" begin="975" duration="4000" mode="EaseOut"/>
			</storyboard>
		</image>
		<image name="art">
			<pos>0.5 0.89</pos>
		</image>
		
		<image name="fanart">
			<pos>0.5 0</pos>
			<color>FFFFFF5F</color>
			<opacity>1</opacity>
			<size if="${screen.ratio} == '4/3'">1.28 0</size>
			<size if="${screen.ratio} == '16/10'">1.11 0</size>
			<storyboard event="activate" repeat="forever">
				<animation property="scale" from="1" to="1.1" duration="8000"/>
				<animation property="scale" begin="8000" to="1" duration="8000"/>
			</storyboard>
			<storyboard event="deactivate">
				<animation property="opacity" to="0" duration="400" mode="easeOut"/>
				<animation property="scale" to="1" duration="250"/>
			</storyboard>
		</image>
		<image name="fanart_fix">
			<pos>0.5 -0.3</pos>
			<color>FFFFFF16</color>
			<opacity>1</opacity>
		</image>
		<image name="md_marquee">
			<visible>true</visible>
			<pos>0.185 0.14</pos>
			<maxSize>0.25 0.14</maxSize>
			<zIndex>36</zIndex>
		</image>
		<text name="md_description">
			<pos>0.065 0.267</pos>
			<size>0.34 0.16</size>
			<color>D0D0D0</color>
			<glowColor>00000035</glowColor>
			<glowSize>1</glowSize>
			<glowOffset>3 2</glowOffset>
		</text>
		<video name="md_video">
			<pos>0.785 0.403</pos>
			<showSnapshotNoVideo>false</showSnapshotNoVideo>
			<showSnapshotDelay>true</showSnapshotDelay>
			<snapshotSource>image</snapshotSource>
			<storyboard event="activateNext">
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
			<storyboard event="activatePrev">
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
		</video>

		<image name="art-shadow-left" extra="true">
			<origin>0.5 0.5</origin>
			<pos>-0.018 0.722</pos>
			<size>0.22 0.2</size>
			<rotation>90</rotation>
			<color>141414</color>
			<path>${themePath}/_inc/images/gradient.png</path>
			<linearSmooth>true</linearSmooth>
			<zIndex>109</zIndex>
			<visible if="${screen.ratio} == '21/9'">false</visible>
			<size if="${screen.ratio} == '4/3'">0.28 0.2</size>
			<origin if="${screen.ratio} == '4/3'">0.6 0.4</origin>
		</image>
		<image name="art-shadow-right" extra="true">
			<origin>0.5 0.5</origin>
			<pos>1.018 0.722</pos>
			<size>0.22 0.2</size>
			<rotation>-90</rotation>
			<color>141414</color>
			<path>${themePath}/_inc/images/gradient.png</path>
			<linearSmooth>true</linearSmooth>
			<zIndex>109</zIndex>
			<visible if="${screen.ratio} == '21/9'">false</visible>
			<size if="${screen.ratio} == '4/3'">0.28 0.2</size>
			<origin if="${screen.ratio} == '4/3'">0.4 0.4</origin>
		</image>

		<gamecarousel name="gamecarousel">
			<type>horizontal</type>
			<pos>0 0</pos>
			<size>1.35 1</size>
			<logoScale>1.4</logoScale>
			<color>00000000</color>
			<logoAlignment>bottom</logoAlignment>
			<minLogoOpacity>0.6</minLogoOpacity>
			<transitionSpeed>750</transitionSpeed>
			<!-- <transitionSpeed>1500</transitionSpeed> -->
			<!-- <transitionSpeed>2000</transitionSpeed> -->
			<imageSource>thumbnail</imageSource>
			<defaultTransition>instant</defaultTransition>
			<logoSize>0.350 0.350</logoSize>
			<logoPos>0.325 0.5</logoPos>
			<zIndex>100</zIndex>
			<maxLogoCount>10</maxLogoCount>
			<maxLogoCount if="${screen.ratio} == '21/9'">12</maxLogoCount>
			<maxLogoCount if="${screen.ratio} == '4/3'">8</maxLogoCount>
			<itemTemplate>
				<container>
					<image name="thumbnail-vert">
						<visible if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">false</visible>
						<pos>0.5 0.6</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<maxSize>0.36 1</maxSize>
						<origin if="${screen.ratio} == '21/9'">0.5 0.45</origin>
						<maxSize if="${screen.ratio} == '21/9'">0.30 1</maxSize>
						<origin if="${screen.ratio} == '4/3'">0.5 0.4</origin>
						<maxSize if="${screen.ratio} == '4/3'">0.46 1</maxSize>
						<path>{game:thumbnail}</path>
						<path ifSubset="boxsource:thumbnail">{game:thumbnail}</path>
						<path ifSubset="boxsource:boxart">{game:boxart}</path>
						<path ifSubset="boxsource:image">{game:image}</path>
						<path ifSubset="boxsource:mix">{game:mix}</path>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.6" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
							<!-- <animation property="x" to="0" begin="1350" duration="350" mode="Linear"/> -->
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
					</image>
					<image name="thumbnail-hor">
						<visible>false</visible>
						<visible if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">{game:region} != 'jp'</visible>
						<pos>0.5 0.6</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<rotation>90</rotation>
						<maxSize>0.53 1</maxSize>
						<path>{game:thumbnail}</path>
						<path ifSubset="boxsource:thumbnail">{game:thumbnail}</path>
						<path ifSubset="boxsource:boxart">{game:boxart}</path>
						<path ifSubset="boxsource:image">{game:image}</path>
						<path ifSubset="boxsource:mix">{game:mix}</path>
						<origin if="${screen.ratio} == '21/9'">0.5 0.49</origin>
						<maxSize if="${screen.ratio} == '21/9'">0.46 1</maxSize>
						<origin if="${screen.ratio} == '4/3'">0.5 0.4</origin>
						<maxSize if="${screen.ratio} == '4/3'">0.66 1</maxSize>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.7" begin="0" duration="0" mode="Linear"/>
							<animation property="rotation" to="0" begin="" duration="350" mode="easeOut"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
							<!-- <animation property="x" to="0" begin="1350" duration="350" mode="Linear"/> -->
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="rotation" to="90" begin="" duration="150" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="rotation" to="90" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
					</image>
					<image name="thumbnail-jp">
						<visible>false</visible>
						<visible if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">{game:region} == 'jp'</visible>
						<pos>0.5 0.6</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<rotation>0</rotation>
						<maxSize>0.36 1</maxSize>
						<origin if="${screen.ratio} == '21/9'">0.5 0.45</origin>
						<maxSize if="${screen.ratio} == '21/9'">0.30 1</maxSize>
						<origin if="${screen.ratio} == '4/3'">0.5 0.4</origin>
						<maxSize if="${screen.ratio} == '4/3'">0.46 1</maxSize>
						<path>{game:thumbnail}</path>
						<path ifSubset="boxsource:thumbnail">{game:thumbnail}</path>
						<path ifSubset="boxsource:boxart">{game:boxart}</path>
						<path ifSubset="boxsource:image">{game:image}</path>
						<path ifSubset="boxsource:mix">{game:mix}</path>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.6" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
							<!-- <animation property="x" to="0" begin="1350" duration="350" mode="Linear"/> -->
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
					</image>
					<image name="nothumb">
						<visible>!exists({game:thumbnail}) &amp;&amp; !exists({game:marquee})</visible>
						<pos>0.5 0.6</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<rotation>0</rotation>
						<maxSize>0.38 0.38</maxSize>
						<path>${themePath}/_inc/images/invader.png</path>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.65" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="0.8" duration="150" mode="EaseOut"/>
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="0" duration="0" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="0" duration="0" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
					</image>
					<image name="nothumb-marq">
						<visible>!exists({game:thumbnail})</visible>
						<pos>0.5 0.55</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<rotation>0</rotation>
						<maxSize>0.33 1</maxSize>
						<path>{game:marquee}</path>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.65" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
							<!-- <animation property="x" to="0" begin="1350" duration="350" mode="Linear"/> -->
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
					</image>
					<text name="gamename">
						<visible>!exists({game:marquee}) &amp;&amp; !exists({game:thumbnail})</visible>
						<origin>0.5</origin>
						<text>{game:name}</text>
						<fontPath>${fontNameBold}</fontPath>
						<color>FFFFFF</color>
						<alignment>center</alignment>
						<fontSize>0.025</fontSize>
						<lineSpacing>1</lineSpacing>
						<size>0.3 2</size>
						<pos>0.5 0.8</pos>
						<glowColor>00000066</glowColor>
						<glowSize>2</glowSize>
						<zIndex>400</zIndex>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.65" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="0" duration="0" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="0" duration="0" mode="Linear"/>
							<animation property="opacity" to="0.5" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
					</text>
				</container>
			</itemTemplate>
		</gamecarousel>
	</customView>
</theme>