<?xml version="1.0" encoding="UTF-8"?>
<theme>
<formatVersion>7</formatVersion>
<!-- Шапка + Видео + Список -->
<customView name="WallpapersHeroesListHor" inherits="detailed" displayName="${WallpapersHeroesListHorName}">
		<!-- Disable detailed icons -->
		<container name="container-gamedata">
			<visible>false</visible>
		</container>
		<container name="container-gamedata2">
			<visible>false</visible>
		</container>
		<stackpanel name="container-gamedata3">
			<visible>false</visible>
		</stackpanel>
		<stackpanel name="container-flags">
			<visible>false</visible>
		</stackpanel>
		<stackpanel name="container-icons">
			<visible>false</visible>
		</stackpanel>


		<textlist name="gamelist">
			<pos>0.74 0.59</pos>
			<size>0.25 0.35</size>
			<lines>11</lines>
			<zIndex>180</zIndex>
			<fontPath>${fontNameBold}</fontPath>
			<!-- 4:3 -->
			<pos if="${screen.ratio} == '4/3'">0.74 0.56</pos>
			<size if="${screen.ratio} == '4/3'">0.25 0.38</size>
			<lines if="${screen.ratio} == '4/3'">7</lines>
			<fontSize if="${screen.ratio} == '4/3'">0.03</fontSize>
		</textlist>
		<image name="gamelist-background">
			<visible>false</visible>
		</image>
		<image name="art">
			<color>141414</color>
			<pos>0.5 0.94</pos>
			<zIndex>70</zIndex>
		</image>
		<image name="background">
			<color>141414</color>
		</image>
		
		<image name="fanart">
			<pos>0.5 0</pos>
			<color>FFFFFF5F</color>
			<size>1 0</size>
			<opacity>1</opacity>
			<size if="${screen.ratio} == '4/3'">1.3 0</size>
			<size if="${screen.ratio} == '16/10'">1.11 0</size>
			<storyboard event="activate" repeat="forever">
				<animation property="scale" from="1" to="1.1" duration="8000"/>
				<animation property="scale" begin="8000" to="1" duration="8000"/>
			</storyboard>
			<storyboard event="deactivate">
				<animation property="opacity" to="0" duration="400" mode="easeOut"/>
				<animation property="scale" to="1" duration="250"/>
			</storyboard>
		</image>
		<image name="fanart_fix">
			<pos>0.5 -0.3</pos>
			<color>FFFFFF16</color>
			<opacity>1</opacity>
			<origin>0.5 0</origin>
		</image>
		
		<image name="thumbnail-art">
			<pos>0.13 0.932</pos>
			<maxSize>0.24 0.62</maxSize>
		</image>
		
		<text name="md_name">
			<visible>false</visible>
		</text>
		<text name="md_description">
			<pos>0.273 0.71</pos>
			<size>0.455 0.23</size>
			<pos if="${screen.ratio} == '4/3'">0.273 0.72</pos>
			<size if="${screen.ratio} == '4/3'">0.455 0.22</size>
			<color>D0D0D0D0</color>
		</text>
		<text name="folderpath">
			<pos>0.747 0.57</pos>
			<size>0.239 0.02</size>
		</text>
		<text name="filterInfo">
			<pos>0.747 0.55</pos>
			<size>0.239 0.02</size>
		</text>

		<video name="md_video">
			<pos>0.5 0</pos>
			<maxSize>0.6</maxSize>
			<origin>0.5 0</origin>
			<showSnapshotNoVideo>true</showSnapshotNoVideo>
			<showSnapshotDelay>false</showSnapshotDelay>
			<zIndex>61</zIndex>
		</video>
		<image name="logo">
			<pos>0.1 0.12</pos>
			<maxSize>0.156</maxSize>
		</image>
		<!-- Logo anim bzz -->
		<image name="logo1">
			<pos>0.1 0.12</pos> <!-- Должно совпадать с logo -->
			<maxSize>0.156</maxSize> <!-- Должно совпадать с logo -->
		</image>
		<image name="md_marquee">
			<linearSmooth>true</linearSmooth>
			<visible>true</visible>
			<zIndex>175</zIndex>
			<origin>0.5 0.5</origin>
			<pos>0.9 0.12</pos>
			<maxSize>0.156</maxSize>
			<storyboard repeatAt="200">
				<animation property="y" from="-0.2" begin="0" duration="200" mode="linear"/>
				<animation property="scale" from="1" to="1.05" begin="300" duration="1000" mode="easeOut"/>
				<animation property="scale" from="1.05" to="1" begin="1300" duration="1000" mode="easeOut"/>
			</storyboard>
		</image>

	<!-- Панель с иконками игроков, ачивок, руля и т.д.-->
		<stackpanel name="stackpanel-icons">
			<separator>0.01</separator>
			<pos>0.273 0.59</pos>
			<size>0.455 0.032</size>
			<pos if="${screen.ratio} == '4/3'">0.273 0.56</pos>
			<size if="${screen.ratio} == '4/3'">0.455 0.05</size>
			<orientation>horizontal</orientation>
			<zIndex>150</zIndex>
			
			<text name="icons-players">
				<fontPath>${fontPlayers}</fontPath>
				<text>{game:playerCount}</text>
				<alignment>center</alignment>
				<fontSize>0.03</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.036</fontSize>
				<color>D0D0D0D0</color>
			</text>
			<image name="icons-manual">
				<visible>{game:hasManual}</visible>
				<path>${themePath}/_inc/images/book.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-cheevos">
				<visible>{game:cheevos}</visible>
				<path>${themePath}/_inc/icons/Contest.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			<image name="icons-save">
				<visible>{game:hasSaveState}</visible>
				<path>${themePath}/_inc/icons/SaveState.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-wheel">
				<visible>{game:wheelGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/wheel.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-gun">
				<visible>{game:gunGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/gun.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-padtokey">
				<visible>{game:hasKeyboardMapping}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/padtokey.png</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-hidden">
				<visible>{game:hidden}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/hidden.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			<image name="icons-kid">
				<visible>{game:kidGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/kid.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
		</stackpanel>

	<!-- 2 панель -->
		<stackpanel name="2st-line">
			<separator>0.01</separator>
			<pos>0.273 0.63</pos>
			<size>0.455 0.032</size>
			<pos if="${screen.ratio} == '4/3'">0.273 0.62</pos>
			<size if="${screen.ratio} == '4/3'">0.455 0.042</size>
			<orientation>horizontal</orientation>
			<zIndex>150</zIndex>
			
			<!-- Год выпуска -->
			<image name="icons-releaseyear">
				<path>${themePath}/_inc/images/game_info_releasedate.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>!empty({game:releaseyear})</visible>
			</image>
			<text name="gamedata-releaseyear">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:releaseyear}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>!empty({game:releaseyear})</visible>
			</text>
			
			<!-- Издатель (если не = разработчику) -->
			<image name="icons-publisher">
				<path>${themePath}/_inc/images/game_info_publisher.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:publisher})</visible>
			</image>
			<text name="gamedata-publisher">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:publisher}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:publisher})</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Разработчик (если не = издателю) -->
			<image name="icons-developer">
				<path>${themePath}/_inc/images/game_info_developer.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:developer})</visible>
				<visible if="${screen.ratio} == '4/3'">false</visible>
			</image>
			<text name="gamedata-developer">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:developer}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:developer})</visible>
				<visible if="${screen.ratio} == '4/3'">false</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Если издатель == разработчик -->
			<image name="icons-developer-publisher">
				<path>${themePath}/_inc/images/game_info_publisher.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
			</image>
			<image name="icons-developer-publisher2">
				<path>${themePath}/_inc/images/game_info_developer.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
			</image>
			<text name="gamedata-developer-publisher">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:developer}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Жанр -->
			<image>
				<path>${themePath}/_inc/images/game_info_genre.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>!empty({game:genre})</visible>
			</image>
			<text>
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:genre}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>!empty({game:genre})</visible>
			</text>
		</stackpanel>
	
	<!-- 3 панель -->
		<stackpanel name="3st-line">
			<separator>0.01</separator>
			<pos>0.273 0.67</pos>
			<size>0.455 0.032</size>
			<pos if="${screen.ratio} == '4/3'">0.273 0.672</pos>
			<size if="${screen.ratio} == '4/3'">0.455 0.042</size>
			<orientation>horizontal</orientation>
			<zIndex>150</zIndex>
			<!-- Флаги / Flags -->
			<image name="flag-region">
				<path>${themePath}/_inc/images/flags/{game:region}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>{game:region} != {game:lang} &amp;&amp; !contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-force-world">
				<path>${themePath}/_inc/images/flags/wr.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-lang">
				<path>${themePath}/_inc/images/flags/{game:lang}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>!contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</image>
			<text name="gamedata-lang">
				<fontSize>0.019</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:lang}.upper()</text>
				<color>D0D0D0D0</color>
				<singleLineScroll>true</singleLineScroll>
				<autoScrollDelay>0</autoScrollDelay>
				<y>0.02</y>
				<visible>contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</text>
			<!-- Рейтинг -->
			<text name="gamedata-stars">
				<fontSize>0.028</fontSize>
				<text>{game:stars}</text>
				<color>D0D0D0D0</color>
				<visible>!empty({game:stars})</visible>
			</text>
			<text name="container-separator2">
				<text>•</text>
				<fontSize>0.03</fontSize>
				<color>D0D0D0D0</color>
				<fontPath>${fontNameReg}</fontPath>
				<visible>({game:playcount}) &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Кол-во запусков -->
			<image name="icons-playcount">
				<path>${themePath}/_inc/images/game_info_playcount3.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:playcount} &gt; 0 ? 1 : 0</visible>
			</image>
			<text name="gamedata-playcount">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:playcount}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<visible>{game:playcount} &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Время игры -->
			<image name="icons-gametime">
				<path>${themePath}/_inc/images/game_info_gametime.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</image>
			<text name="gamedata-gametime">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>expandseconds({game:gametime})</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Последний запуск -->
			<image name="icons-lastplayed">
				<path>${themePath}/_inc/images/game_info_lastplayed.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			<visible if="${screen.ratio} == '4/3'">false</visible>
			</image>
			<text name="gamedata-lastplayed">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>day({game:lastplayed}) + '.' + month({game:lastplayed}) + '.' + year({game:lastplayed})</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
				<visible if="${screen.ratio} == '4/3'">false</visible>
			</text>
		</stackpanel>
	</customView>
</theme>