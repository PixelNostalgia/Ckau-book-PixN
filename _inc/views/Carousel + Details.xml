<?xml version="1.0" encoding="UTF-8"?>
<theme>
<formatVersion>7</formatVersion>
<!-- Карусель + подробно -->
	<customView name="Carousel + Details" inherits="gamecarousel" displayName="${carouselDetailsViewName}">
	<!-- Disable gamecarousel view -->
	<image name="thumbnail-art">
		<visible>false</visible>
	</image>
	<image name="gamelist-background">
		<visible>false</visible>
	</image>
	<stackpanel name="container-icons">
		<visible>false</visible>
	</stackpanel>
	<container name="container-gamedata">
		<visible>false</visible>
	</container>
	<container name="container-gamedata2">
		<visible>false</visible>
	</container>
	<stackpanel name="container-gamedata3">
		<visible>false</visible>
	</stackpanel>
	<stackpanel name="container-flags">
		<visible>false</visible>
	</stackpanel>

	<!-- Панель с иконками игроков, ачивок, руля и т.д.-->
		<stackpanel name="stackpanel-icons">
			<separator>0.01</separator>
			<pos>0.04 0.80</pos>
			<size>0.62 0.032</size>
			<size if="${screen.ratio} == '4/3'">0.62 0.036</size>
			<orientation>horizontal</orientation>
			<zIndex>750</zIndex>
			
			<image name="icons-favorite">
				<visible>{game:favorite}</visible>
				<path>${themePath}/_inc/images/heart.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			<text name="icons-players">
				<fontPath>${fontPlayers}</fontPath>
				<text>{game:playerCount}</text>
				<alignment>center</alignment>
				<fontSize>0.03</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.036</fontSize>
				<color>D0D0D0D0</color>
			</text>
			<image name="icons-manual">
				<visible>{game:hasManual}</visible>
				<path>${themePath}/_inc/images/book.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-cheevos">
				<visible>{game:cheevos}</visible>
				<path>${themePath}/_inc/icons/Contest.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			<image name="icons-save">
				<visible>{game:hasSaveState}</visible>
				<path>${themePath}/_inc/icons/SaveState.png</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-wheel">
				<visible>{game:wheelGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/wheel.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-gun">
				<visible>{game:gunGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/gun.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-padtokey">
				<visible>{game:hasKeyboardMapping}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/padtokey.png</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			
			<image name="icons-hidden">
				<visible>{game:hidden}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/hidden.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
			<image name="icons-kid">
				<visible>{game:kidGame}</visible>
				<linearSmooth>true</linearSmooth>
				<padding>0 0</padding>
				<path>${themePath}/_inc/images/kid.svg</path>
				<maxSize>1 1</maxSize>
				<color>D0D0D0D0</color>
			</image>
		</stackpanel>

	<!-- 2 панель -->
		<stackpanel name="2st-line">
			<separator>0.01</separator>
			<pos>0.04 0.84</pos>
			<size>0.62 0.032</size>
			<size if="${screen.ratio} == '4/3'">0.62 0.036</size>
			<orientation>horizontal</orientation>
			<zIndex>750</zIndex>
			
			<!-- Год выпуска -->
			<image name="icons-releaseyear">
				<path>${themePath}/_inc/images/game_info_releasedate.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>!empty({game:releaseyear})</visible>
			</image>
			<text name="gamedata-releaseyear">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:releaseyear}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>!empty({game:releaseyear})</visible>
			</text>
			
			<!-- Издатель (если не = разработчику) -->
			<image name="icons-publisher">
				<path>${themePath}/_inc/images/game_info_publisher.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:publisher})</visible>
			</image>
			<text name="gamedata-publisher">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:publisher}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:publisher})</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Разработчик (если не = издателю) -->
			<image name="icons-developer">
				<path>${themePath}/_inc/images/game_info_developer.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:developer})</visible>
			</image>
			<text name="gamedata-developer">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:developer}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} != {game:developer} &amp;&amp; !empty({game:developer})</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Если издатель == разработчик -->
			<image name="icons-developer-publisher">
				<path>${themePath}/_inc/images/game_info_publisher.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
			</image>
			<image name="icons-developer-publisher2">
				<path>${themePath}/_inc/images/game_info_developer.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
			</image>
			<text name="gamedata-developer-publisher">
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:developer}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<visible>{game:publisher} == {game:developer} &amp;&amp; !empty({game:publisher}) &amp;&amp; !empty({game:developer})</visible>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
			</text>
			
			<!-- Жанр -->
			<image>
				<path>${themePath}/_inc/images/game_info_genre.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>!empty({game:genre})</visible>
			</image>
			<text>
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:genre}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 4 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>!empty({game:genre})</visible>
			</text>
		</stackpanel>
	
	<!-- 3 панель -->
		<stackpanel name="3st-line">
			<separator>0.01</separator>
			<pos>0.04 0.88</pos>
			<size>0.62 0.032</size>
			<size if="${screen.ratio} == '4/3'">0.62 0.036</size>
			<orientation>horizontal</orientation>
			<zIndex>750</zIndex>
			<!-- Флаги / Flags -->
			<image name="flag-region">
				<path>${themePath}/_inc/images/flags/{game:region}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>{game:region} != {game:lang} &amp;&amp; !contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-force-world">
				<path>${themePath}/_inc/images/flags/wr.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-lang">
				<path>${themePath}/_inc/images/flags/{game:lang}.png</path>
				<maxSize>0.8</maxSize>
				<origin>0.5 0.5</origin>
				<pos>0.5 0.4</pos>
				<linearSmooth>true</linearSmooth>
				<opacity>0.8</opacity>
				<visible>!contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</image>
			<text name="gamedata-lang">
				<fontSize>0.019</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:lang}.upper()</text>
				<color>D0D0D0D0</color>
				<singleLineScroll>true</singleLineScroll>
				<autoScrollDelay>0</autoScrollDelay>
				<y>0.02</y>
				<visible>contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</text>
			<!-- Рейтинг -->
			<text name="gamedata-stars">
				<fontSize>0.028</fontSize>
				<text>{game:stars}</text>
				<color>D0D0D0D0</color>
				<visible>!empty({game:stars})</visible>
			</text>
			<text name="container-separator2">
				<text>•</text>
				<fontSize>0.03</fontSize>
				<color>D0D0D0D0</color>
				<fontPath>${fontNameReg}</fontPath>
				<visible>({game:playcount}) &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Кол-во запусков -->
			<image name="icons-playcount">
				<path>${themePath}/_inc/images/game_info_playcount3.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:playcount} &gt; 0 ? 1 : 0</visible>
			</image>
			<text name="gamedata-playcount">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:playcount}</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<visible>{game:playcount} &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Время игры -->
			<image name="icons-gametime">
				<path>${themePath}/_inc/images/game_info_gametime.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</image>
			<text name="gamedata-gametime">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>expandseconds({game:gametime})</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</text>
			
			<!-- Последний запуск -->
			<image name="icons-lastplayed">
				<path>${themePath}/_inc/images/game_info_lastplayed.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>D0D0D0D0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</image>
			<text name="gamedata-lastplayed">
				<fontSize>0.022</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.029</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>day({game:lastplayed}) + '.' + month({game:lastplayed}) + '.' + year({game:lastplayed})</text>
				<color>D0D0D0D0</color>
				<padding>4 0 12 0</padding>
				<multiLine>false</multiLine>
				<autoScrollDelay>3000</autoScrollDelay>
				<singleLineScroll>true</singleLineScroll>
				<visible>{game:gametime} &gt; 0 ? 1 : 0</visible>
			</text>
		</stackpanel>

		<image name="art">
			<pos>0.5 0.62</pos>
		</image>

		<image name="fanart">
			<color>FFFFFF3F</color>
			<opacity>1</opacity>
		</image>
		<image name="fanart_fix">
			<opacity>1</opacity>
		</image>

		<image name="md_marquee">
			<pos>0.815 0.12</pos>
			<maxSize>0.240 0.126</maxSize>
			<origin>0.5 0.5</origin>
			<visible>true</visible>
			<zIndex>120</zIndex>
			<maxSize if="${screen.ratio} == '21/9'">0.2 0.126</maxSize>
		</image>
		<image name="md_cartridge">
			<visible>true</visible>
			<origin>0.5 0.5</origin>
			<pos>0.5 0.5</pos>
			<maxSize>0.215 0.45</maxSize>
			<maxSize if="${screen.ratio} == '4/3'">0.245 0.45</maxSize>
		</image>
		<image name="logo">
			<pos>0.16 0.12</pos>
			<maxSize>0.240 0.126</maxSize>
			<origin>0.5 0.5</origin>
			<zIndex>150</zIndex>
			<maxSize if="${screen.ratio} == '21/9'">0.2 0.126</maxSize>
			<storyboard>
				<animation property="opacity" to="1" begin="0" duration="0" mode="EaseIn"/>
			</storyboard>
		</image>
		<!-- Logo anim bzz -->
		<image name="logo1">
			<pos>0.16 0.12</pos> <!-- Должно совпадать с logo -->
			<maxSize>0.240 0.126</maxSize> <!-- Должно совпадать с logo -->
			<origin>0.5 0.5</origin> <!-- Должно совпадать с logo -->
			<opacity>0</opacity>
			<zIndex>20</zIndex>
			<maxSize if="${screen.ratio} == '21/9'">0.2 0.126</maxSize>
			<storyboard>
				<animation property="opacity" from="0.75" to="0" begin="995" duration="4000" mode="EaseOut"/>
				<animation property="scale" from="1.05" to="1.4" begin="995" duration="4000" mode="EaseOut"/>
				<animation property="color" from="FFAAAA" to="FF7777" begin="975" duration="4000" mode="EaseOut"/>
			</storyboard>
			<storyboard event="activate">
			</storyboard>
		</image>

		<video name="md_video">
			<pos>0.815 0.455</pos>
			<maxSize>0.30 0.383</maxSize>
			<origin>0.5 0.5</origin>
		</video>
		<text name="md_description">
			<fontPath>${fontNameReg}</fontPath>
			<pos>0.665 0.66</pos>
			<size>0.31 0.26</size>
			<color>D0D0D0D0</color>
			<lineSpacing>1.1</lineSpacing>
			<zIndex>110</zIndex>
			<visible>true</visible>
		</text>

		<image name="art-shadow-left" extra="true">
			<origin>0.5 0.5</origin>
			<pos>-0.034 0.53</pos>
			<size>0.28 0.2</size>
			<rotation>90</rotation>
			<color>141414</color>
			<path>${themePath}/_inc/images/gradient.png</path>
			<linearSmooth>true</linearSmooth>
			<zIndex>109</zIndex>
			<origin if="${screen.ratio} == '21/9'">0.5 0.53</origin>
			<pos if="${screen.ratio} == '21/9'">-0.0155 0.55</pos>
			<size if="${screen.ratio} == '21/9'">0.18 0.2</size>
			<origin if="${screen.ratio} == '4/3'">0.53 0.55</origin>
			<size if="${screen.ratio} == '4/3'">0.4 0.2</size>
		</image>
		<image name="art-shadow-right" extra="true">
			<origin>0.5 0.5</origin>
			<pos>0.69 0.53</pos>
			<size>0.24 0.2</size>
			<rotation>-90</rotation>
			<color>141414</color>
			<path>${themePath}/_inc/images/gradient.png</path>
			<linearSmooth>true</linearSmooth>
			<zIndex>109</zIndex>
			<origin if="${screen.ratio} == '21/9'">0.5 0.53</origin>
			<pos if="${screen.ratio} == '21/9'">0.66 0.55</pos>
			<size if="${screen.ratio} == '21/9'">0.18 0.2</size>
			<origin if="${screen.ratio} == '4/3'">0.45 0.5</origin>
			<size if="${screen.ratio} == '4/3'">0.34 0.2</size>
		</image>

		<gamecarousel name="gamecarousel">
			<type>horizontal</type>
			<pos>-0.16 0.08</pos>
			<size>0.82 1</size>
			<logoScale>1.6</logoScale>
			<color>00000000</color>
			<logoAlignment>bottom</logoAlignment>
			<minLogoOpacity>0.6</minLogoOpacity>
			<transitionSpeed>750</transitionSpeed>
			<!-- <transitionSpeed>1500</transitionSpeed> -->
			<!-- <transitionSpeed>2000</transitionSpeed> -->
			<imageSource>thumbnail</imageSource>
			<defaultTransition>instant</defaultTransition>
			<logoSize>0.350 0.350</logoSize>
			<logoPos>0.15 0.25</logoPos>
			<zIndex>100</zIndex>
			<maxLogoCount>6</maxLogoCount>
			<maxLogoCount if="${screen.ratio} == '21/9'">8</maxLogoCount>
			<maxLogoCount if="${screen.ratio} == '4/3'">5</maxLogoCount>
			<itemTemplate>
				<container>
					<image name="thumbnail-vert">
						<visible if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">false</visible>
						<pos>0.5 0.6</pos>
						<origin>0.5</origin>
						<linearSmooth>true</linearSmooth>
						<maxSize>0.36 1</maxSize>
						<path>{game:thumbnail}</path>
						<path ifSubset="boxsource:thumbnail">{game:thumbnail}</path>
						<path ifSubset="boxsource:boxart">{game:boxart}</path>
						<path ifSubset="boxsource:image">{game:image}</path>
						<path ifSubset="boxsource:mix">{game:mix}</path>
						<maxSize if="${screen.ratio} == '21/9'">0.30 1</maxSize>
						<maxSize if="${screen.ratio} == '4/3'">0.44 1</maxSize>
						<!-- <opacity>0</opacity> -->
						<storyboard event="activate">
							<animation property="y" to="0.65" begin="250" duration="350" mode="easeIn"/>
							<animation property="opacity" to="1" duration="150" mode="EaseOut"/>
							<!-- <animation property="x" to="0.2" begin="1350" duration="350" mode="Linear"/> -->
						</storyboard>
						<storyboard event="deactivate">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="150" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<storyboard event="scroll">
							<animation property="y" to="0.6" begin="" duration="" mode="Linear"/>
							<animation property="opacity" to="0.7" duration="1" mode="EaseOut"/>
							<animation property="opacity" to="0" begin="1400" duration="600" mode="EaseOut"/>
						</storyboard>
						<!-- <shader>
							<path>:/shaders/border.glsl</path>
							<cornerRadius>0.01</cornerRadius>
							<innerShadowSize>0.01</innerShadowSize>
							<innerShadowColor>00000030</innerShadowColor>
							<outerShadowSize>0.020</outerShadowSize>
							<outerShadowColor>00000050</outerShadowColor>
						</shader> -->
