<?xml version="1.0" encoding="UTF-8"?>
<theme>
<formatVersion>7</formatVersion>
<!-- Сетка -->
	<view name="grid">
		<text name="md_description">
			<visible>false</visible>
		</text>
		<image name="art">
			<pos>0.5 0.6</pos>
		</image>
		<imagegrid name="gamegrid">
			<pos>0.016 0.16</pos>
			<size>0.95 0.79</size>
			<margin>0.005 0.010</margin>
			<padding>0.03 0.04 0.03 0.1</padding>
			<autoLayout>7 2</autoLayout>
			<autoLayout if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">5 3</autoLayout>
			<autoLayoutSelectedZoom>1.12</autoLayoutSelectedZoom>
			<centerSelection>false</centerSelection>
			<animateSelection>false</animateSelection>
			<scrollbarColor>333333FF</scrollbarColor>
			<scrollbarCorner>0.49</scrollbarCorner>
			<scrollbarSize>0.005</scrollbarSize>
			<autoLayout if="${screen.ratio} == '4/3'">5 2</autoLayout>
			<autoLayout if="${screen.ratio} == '21/9'">9 2</autoLayout>
			<scrollbarAlignment if="${screen.ratio} == '4/3'">left</scrollbarAlignment>
			
			<autoLayout if="${screen.ratio} == '21/9' && {system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">7 3</autoLayout>
			<autoLayout if="${screen.ratio} == '4/3' && {system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">4 3</autoLayout>
			<zIndex>50</zIndex>
		</imagegrid>
		<gridtile name="default">
			<backgroundColor>FFFFFF00</backgroundColor>
			<backgroundCornerSize>9 9</backgroundCornerSize>
			<selectionMode>image</selectionMode>
			<padding>5 5</padding>
			<imageColor>FFFFFFB0</imageColor>
		</gridtile>
		<gridtile name="selected">
			<backgroundCenterColor>${centerFadeColor}</backgroundCenterColor>
			<backgroundEdgeColor>${bottomBarColor}</backgroundEdgeColor>
			<imageColor>FFFFFFFF</imageColor>
		</gridtile>
		<text name="gridtile">
			<color>D0D0D0</color>
			<backgroundColor>00000000</backgroundColor>
			<fontSize>0.022</fontSize>
			<alignment>center</alignment>
			<size>1 0.24</size>
			<!-- <multiLine>false</multiLine>
			<autoScrollDelay>1</autoScrollDelay>
			<singleLineScroll>true</singleLineScroll> -->
			<visible>false</visible>
		</text>
		<text name="gridtile:selected">
			<color>FFFFFF</color>
			<glowColor>${glowColor}</glowColor>
			<glowSize>2</glowSize>
			<visible>false</visible>
		</text>
		<!-- <text name="gridtile">
			<color>D0D0D0</color>
			<backgroundColor>00000000</backgroundColor>
			<fontSize>0.022</fontSize>
			<alignment>center</alignment>
			<size>1 0.24</size>
			<multiLine>false</multiLine>
			<autoScrollDelay>1</autoScrollDelay>
			<singleLineScroll>true</singleLineScroll>
		</text>
		<text name="gridtile:selected">
			<color>FFFFFF</color>
			<glowColor>${glowColor}</glowColor>
			<glowSize>2</glowSize>
		</text> -->
		<image name="gridtile.image">
			<linearSmooth>true</linearSmooth>
		</image>
		<image name="gridtile.favorite">
			<path>${themePath}/_inc/images/favorite.png</path>
			<pos>0.9 0.1</pos>
			<maxSize>0.18 0.18</maxSize>
			<origin>0.5 0.5</origin>
			<horizontalAlignment>center</horizontalAlignment>
			<verticalAlignment>top</verticalAlignment>
			<color>FFFF00B0</color>
		</image>
		<image name="gridtile.favorite:selected">
			<color>FFFFFF</color>
		</image>
		<ninepatch name="gridtile.background:selected">
			<path>${themePath}/_inc/images/framewselsq.png</path>
			<cornerSize>36 36</cornerSize>
			<padding>-18 -18</padding>
			<color>${baseColor}</color>
			<animateColor>141414</animateColor>
			<animateColorTime>650</animateColorTime>
		</ninepatch>

		<!-- Вертикальная панель с иконками -->
		<stackpanel name="container-icons-vertical" extra="true">
			<pos>0.973 0.19</pos>
			<size>0.02 0.5</size>
			<orientation>vertical</orientation>
			<zIndex>150</zIndex>
			<separator>0.008</separator>
			<pos if="${screen.ratio} == '4/3'">0.957 0.19</pos>
			<size if="${screen.ratio} == '4/3'">0.038 0.5</size>
			<separator if="${screen.ratio} == '4/3'">0.016</separator>
			
			<!-- Количество игроков -->
			<text name="icons-players">
				<fontPath>${fontPlayers}</fontPath>
				<text>{game:playerCount}</text>
				<alignment>center</alignment>
				<fontSize>0.03</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.04</fontSize>
				<color>666666</color>
				<size>0.1 0.1</size>
			</text>
			
			<!-- Все иконки -->
			<image name="icons-manual">
				<visible>{game:hasManual}</visible>
				<path>${themePath}/_inc/images/book.png</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-cheevos">
				<visible>{game:cheevos}</visible>
				<path>${themePath}/_inc/icons/Contest.png</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-save">
				<visible>{game:hasSaveState}</visible>
				<path>${themePath}/_inc/icons/SaveState.png</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-wheel">
				<visible>{game:wheelGame}</visible>
				<path>${themePath}/_inc/images/wheel.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-gun">
				<visible>{game:gunGame}</visible>
				<path>${themePath}/_inc/images/gun.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-padtokey">
				<visible>{game:hasKeyboardMapping}</visible>
				<path>${themePath}/_inc/images/padtokey.png</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-hidden">
				<visible>{game:hidden}</visible>
				<path>${themePath}/_inc/images/hidden.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
			
			<image name="icons-kid">
				<visible>{game:kidGame}</visible>
				<path>${themePath}/_inc/images/kid.svg</path>
				<linearSmooth>true</linearSmooth>
				<color>666666</color>
				<maxSize>1 1</maxSize>
			</image>
		</stackpanel>

		<stackpanel name="container-icons-vertical-invert" extra="true" reverse="true">
			<pos>0.973 0.42</pos>
			<size>0.02 0.5</size>
			<orientation>vertical</orientation>
			<zIndex>150</zIndex>
			<separator>0.008</separator>
			<pos if="${screen.ratio} == '4/3'">0.957 0.42</pos>
			<size if="${screen.ratio} == '4/3'">0.038 0.5</size>
			<separator if="${screen.ratio} == '4/3'">0.016</separator>
			
			<!-- Флаги / Flags -->
			<image name="flag-region">
				<path>${themePath}/_inc/images/flags/{game:region}.png</path>
				<linearSmooth>true</linearSmooth>
				<maxSize>1 1</maxSize>
				<opacity>0.8</opacity>
				<visible>{game:region} != {game:lang} &amp;&amp; !contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-force-world">
				<path>${themePath}/_inc/images/flags/wr.png</path>
				<linearSmooth>true</linearSmooth>
				<maxSize>1 1</maxSize>
				<opacity>0.8</opacity>
				<visible>contains(lower({game:region}), ',') &amp;&amp; !empty({game:region})</visible>
			</image>
			<image name="flag-lang">
				<path>${themePath}/_inc/images/flags/{game:lang}.png</path>
				<linearSmooth>true</linearSmooth>
				<maxSize>1 1</maxSize>
				<opacity>0.8</opacity>
				<visible>!contains(lower({game:lang}), ',') &amp;&amp; !empty({game:lang})</visible>
			</image>
			<!-- <container name="releaseyear-container">
			<visible>!empty({game:releaseyear})</visible>
			<text>
				<fontSize>0.022</fontSize>
				<fontPath>${fontNameReg}</fontPath>
				<text>{game:releaseyear}</text>
				<size>1.2 1.8</size>
				<color>666666</color>
				<rotation>-90</rotation>
				<pos>-0.1 0</pos>
			</text>
			</container> -->
		</stackpanel>
	</view>
</theme>