<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
<!-- Custom scroll sound -->
	<view name="system, menu, basic, detailed, grid, gamecarousel">
		<textlist name="gamelist">
			<scrollSound>${themePath}/_inc/sound/scroll.wav</scrollSound>
			<scrollSound>${themePath}/_inc/sound/${system.theme}.wav</scrollSound>
			<storyboard>
				<sound path="${themePath}/_inc/sound/scroll-in.wav"/>
			</storyboard>
		</textlist>
		<gamecarousel name="gamecarousel">
			<scrollSound>${themePath}/_inc/sound/scroll.wav</scrollSound>
			<scrollSound>${themePath}/_inc/sound/${system.theme}.wav</scrollSound>
			<storyboard>
				<sound path="${themePath}/_inc/sound/scroll-in.wav"/>
			</storyboard>
		</gamecarousel>
		<imagegrid name="gamegrid">
			<scrollSound>${themePath}/_inc/sound/scroll.wav</scrollSound>
			<scrollSound>${themePath}/_inc/sound/${system.theme}.wav</scrollSound>
			<storyboard>
				<sound path="${themePath}/_inc/sound/scroll-in.wav"/>
			</storyboard>
		</imagegrid>
	</view>
</theme>