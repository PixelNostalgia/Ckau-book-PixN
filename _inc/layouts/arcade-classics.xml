<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<view name="system">
		<!-- fix bg color -->
		<image name="sysbg-fix" extra="true">
			<origin>0.5 0.5</origin>
			<pos>0.5 0.5</pos>
			<maxSize>1 1</maxSize>
			<path>./../../_inc/arts/auto-fix.png</path>
			<!-- Loads 4K image, if addon is available -->
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/arts/4K/auto-fix.png</path>
			<zIndex>26</zIndex>
		</image>
		<image name="sysbg-video">
			<visible>false</visible>
		</image>
		<video name="videobox">
			<path>./../../_inc/videos/${system.theme}.mp4</path>
			<path>./../../_inc/videos/${system.theme}-${lang}.mp4</path>
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/videos/${system.theme}.mp4</path>
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/videos/${system.theme}-${lang}.mp4</path>
			<pos>0.49 0.4929</pos>
			<maxSize>0.555</maxSize>
			<pos if="${screen.ratio} == '16/10'">0.488 0.4929</pos>
			<pos if="${screen.ratio} == '4/3'">0.486 0.4929</pos>
			<pos if="${screen.ratio} == '21/9'">0.492 0.4929</pos>
		</video>
		<text name="TextDate">
			<text/>
		</text>
		<text name="TextManufacturer" extra="true">
			<text>Collection</text>
			<text lang="pl">Kolekcja</text>
			<text lang="ru">Коллекция</text>
			<text lang="es">Recopilación</text>
			<text lang="fr">Collection</text>
			<text lang="it">Collezione</text>
		</text>
		<text name="TextName" extra="true">
			<text>Arcade Classics</text>
			<text lang="pl">Klasyka zręcznościowa</text>
			<text lang="ru">Аркадная классика</text>
			<text lang="es">Clásicos arcade</text>
			<text lang="fr">Classiques d'arcade</text>
			<text lang="it">Classici arcade</text>
		</text>
		<text name="TextDesc" extra="true">
			<text>A collection of classic arcade games. The collection is taken from your available games.</text>
			<text lang="pl">Kolekcja klasycznych gier zręcznościowych. Kolekcja jest pobierana z dostępnych gier.</text>
			<text lang="ru">Коллекция классических аркадных игр. Коллекция взята из имеющихся у вас игр.</text>
			<text lang="es">Una colección de juegos arcade clásicos. La colección se toma de tus juegos disponibles.</text>
			<text lang="de">Eine Sammlung klassischer Arcade-Spiele. Die Sammlung wird aus Ihren verfügbaren Spielen übernommen.</text>
			<text lang="fr">Une collection de jeux d'arcade classiques. La collection est extraite de vos jeux disponibles.</text>
			<text lang="it">Una raccolta di giochi arcade classici. La raccolta è presa dai tuoi giochi disponibili.</text>
		</text>
	</view>
</theme>
