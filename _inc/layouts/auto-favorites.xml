<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<view name="system">
		<image name="sysart">
			<path>./../../_inc/arts/auto-allgames.png</path>
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/arts/4K/auto-allgames.png</path>
		</image>
		<!-- fix bg color -->
		<image name="sysbg-fix" extra="true">
			<origin>0.5 0.5</origin>
			<pos>0.5 0.5</pos>
			<maxSize>1 1</maxSize>
			<path>./../../_inc/arts/auto-fix.png</path>
			<!-- Loads 4K image, if addon is available -->
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/arts/4K/auto-fix.png</path>
			<zIndex>26</zIndex>
		</image>
		<image name="sysbg-video">
			<visible>false</visible>
		</image>
		<video name="videobox">
			<path>./../../_inc/videos/${system.theme}.mp4</path>
			<path>./../../_inc/videos/${system.theme}-${lang}.mp4</path>
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/videos/${system.theme}.mp4</path>
			<path ifSubset="addons:yes">./../../../ckau-book-addons/_inc/videos/${system.theme}-${lang}.mp4</path>
			<pos>0.49 0.4929</pos>
			<maxSize>0.555</maxSize>
			<pos if="${screen.ratio} == '16/10'">0.488 0.4929</pos>
			<pos if="${screen.ratio} == '4/3'">0.486 0.4929</pos>
			<pos if="${screen.ratio} == '21/9'">0.492 0.4929</pos>
		</video>
		<text name="TextDate">
			<text/>
		</text>
		<text name="TextManufacturer">
			<text>Collection</text>
			<text lang="pl">Kolekcja</text>
			<text lang="ru">Коллекция</text>
			<text lang="es">Recopilación</text>
			<text lang="fr">Collection</text>
			<text lang="it">Collezione</text>
			<text lang="pt">Coleção</text>
		</text>
		<text name="TextName">
			<text>Favorites</text>
			<text lang="pl">Ulubione</text>
			<text lang="ru">Избранное</text>
			<text lang="es">Favoritos</text>
			<text lang="fr">Favoris</text>
			<text lang="it">Preferiti</text>
			<text lang="pt">Favoritos</text>
		</text>
		<text name="TextDesc">
			<text>Here's a collection of all games, from all systems, that have been added to favorites.</text>
			<text lang="pl">Oto kolekcja wszystkich gier, z wszystkich systemów, które zostały dodane do ulubionych.</text>
			<text lang="ru">Здесь собраны все игры со всех систем, которые были добавлены в избранное.</text>
			<text lang="es">Aquí tienes una recopilación de todos los juegos, de todos los sistemas, que se han añadido a favoritos.</text>
			<text lang="de">Hier ist eine Sammlung aller Spiele von allen Systemen, die zu den Favoriten hinzugefügt wurden.</text>
			<text lang="fr">Voici une collection de tous les jeux, tous systèmes confondus, qui ont été ajoutés aux favoris.</text>
			<text lang="it">Ecco una raccolta di tutti i giochi, di tutti i sistemi, che sono stati aggiunti ai preferiti.</text>
			<text lang="pt">Esta é a coleção de todos os jogos, de todos os sistemas, que foram adicionados aos favoritos.</text>
		</text>
	</view>
</theme>
