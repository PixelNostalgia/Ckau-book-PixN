			<visible>false</visible>
		</batteryIndicator>
		<!-- Панель с wifi, батареей | Wi-Fi panel, battery -->
		<stackpanel name="batteryIndicatorNew" extra="true">
			<separator>2</separator>
			<reverse>true</reverse>
			<pos>0.4165 0.005</pos>
			<size>0.58 0.0275</size>
			<size if="${screen.ratio} == '4/3'">0.58 0.0475</size>
			<orientation>horizontal</orientation>
			<webimage name="avatar" extra="static" if="{global.cheevos} == true" ifSubset="cheevos-avatar:cheevos" tinyScreen="false">
				<path>https://media.retroachievements.org/UserPic/${global.cheevos.username}.png</path>
				
				<maxSize>1 1</maxSize>
				<linearSmooth>true</linearSmooth>
			</webimage>
			<text name="ss.separator1" if="{global.cheevos} == true" ifSubset="cheevos-avatar:cheevos" tinyScreen="false">
				<text>-</text>
				<fontSize>0.01</fontSize>
				<color>00000000</color>
			</text>
			<text name="ss.cheevosUser" if="{global.cheevos} == true" ifSubset="cheevos-avatar:cheevos" tinyScreen="false">
				<text>${global.cheevos.username}</text>
				<alignment>center</alignment>
				<fontSize>0.022</fontSize>
				<fontSize tinyScreen="true">0.025</fontSize>
				<color>FFFFFFA0</color>
			</text>
			<batteryText name="batterytext">
				<fontPath>${fontNameBold}</fontPath>
				<fontSize>0.024</fontSize>
				<fontSize if="${screen.ratio} == '4/3'">0.04</fontSize>
				<color>FFFFFFA0</color>
			</batteryText>
			<batteryIcon name="battery">
				<incharge>./_inc/images/battery/incharge.svg</incharge>
				<full>./_inc/images/battery/full.svg</full>
				<at75>./_inc/images/battery/75.svg</at75>
				<at50>./_inc/images/battery/50.svg</at50>
				<at25>./_inc/images/battery/25.svg</at25>
				<empty>./_inc/images/battery/empty.svg</empty>
				<linearSmooth>true</linearSmooth>
				<color>FFFFFFA0</color>
				<padding>0 0</padding>
				<maxSize>1 1</maxSize>
			</batteryIcon>
