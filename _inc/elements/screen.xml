<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<view name="screen">
		<text name="clock">
			<fontSize>0.025</fontSize>
			<pos>0.905 0.945</pos>
			<size>0.09 0.058</size>
			<alignment>right</alignment>
			<verticalAlignment>center</verticalAlignment>
			<fontPath>${fontDescReg}</fontPath>
			<!-- 4:3 -->
			<fontSize if="${screen.ratio} == '4/3'">0.034</fontSize>
			<pos if="${screen.ratio} == '4/3'">0.888 0.945</pos>
			<size if="${screen.ratio} == '4/3'">0.1 0.058</size>
		</text>
		<controllerActivity name="controllerActivity">
			<pos>0.005 0.005</pos>
			<size>0.185 0.023</size>
			<itemSpacing>0.003</itemSpacing>
			<color>FFFFFF90</color>
			<!-- controllers -->
			<imagePath>./../images/gamepad.svg</imagePath>
			<gunPath>./../images/gun.svg</gunPath>
			<wheelPath>./../images/wheel.svg</wheelPath>
			<activityColor>${baseColor}</activityColor>
			<hotkeyColor>FFA0A0C0</hotkeyColor>
			<!-- 4:3 -->
			<pos if="${screen.ratio} == '4/3'">0.015 0.005</pos>
			<size if="${screen.ratio} == '4/3'">0.285 0.033</size>
		</controllerActivity>
