<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<include>./blackful.xml</include>
<!-- Variables for Dynamic bg -->
	<variables>
		<sysbgColor>141414</sysbgColor>
	</variables>
	<view name="system">
		<image name="background" extra="static">
			<color>141414</color>
		</image>
		<image name="sysbg-fix" extra="true">
			<color>141414</color>
		</image>
		<image name="sysbg-left" extra="true">
			<color>141414</color>
		</image>
		<image name="sysbg-right" extra="true">
			<color>141414</color>
		</image>
		<image name="sysbg-down" extra="true">
			<color>141414</color>
		</image>
	</view>
</theme>