<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<include>./colorful.xml</include>
<!-- Variables for Dynamic bg -->
	<variables>
		<sysbgColor>000000</sysbgColor>
	</variables>
	<view name="system">
		<image name="background" extra="static">
			<color>000000</color>
		</image>
		<image name="sysbg-fix" extra="true">
			<color>000000</color>
		</image>
		<image name="sysbg-left" extra="true">
			<color>000000</color>
		</image>
		<image name="sysbg-right" extra="true">
			<color>000000</color>
		</image>
		<image name="sysbg-down" extra="true">
			<color>000000</color>
		</image>

<!-- System info desc -->
		<text name="TextDate" extra="true">
			<color>FFFFFF80</color>
		</text>
		<text name="TextManufacturer" extra="true">
			<color>FFFFFF</color>
		</text>
		<text name="TextName" extra="true">
			<color>FFFFFF</color>
		</text>
		<text name="TextVariant" extra="true">
			<color>FFFFFF</color>
		</text>
		<text name="TextDesc" extra="true">
			<color>FFFFFF</color>
		</text>

<!-- Prefer white versions of the logo -->
		<image name="logo">
			<path>./../logos/${system.theme}-w.png</path>
			<path>./../logos/${system.theme}-w.svg</path>
			<path>./../logos/${system.theme}-${lang}-w.png</path>
			<path>./../logos/${system.theme}-${lang}-w.svg</path>
			<!-- Attemps to load synonym if system not available -->
			<path>./../logos/${synonym}-w.png</path>
			<path>./../logos/${synonym}-w.svg</path>
			<path>./../logos/${synonym}-${lang}-w.png</path>
			<path>./../logos/${synonym}-${lang}-w.svg</path>
			<linearSmooth>true</linearSmooth>
		</image>
	<!-- Logos for Collections -->
		<image name="logo" if="{system.collection}">
			<path>./../logos/collections/${system.theme}-w.png</path>
			<path>./../logos/collections/${system.theme}-w.svg</path>
		</image>
	<!-- Regional logos -->
		<image name="logo" region="eu"/>
		<image name="logo" region="us">
			<path>./../logos/us/${system.theme}-w.png</path>
			<path>./../logos/us/${system.theme}-w.svg</path>
			<path>./../logos/us/${synonym}-w.png</path>
			<path>./../logos/us/${synonym}-w.svg</path>
		</image>
		<image name="logo" region="jp">
			<path>./../logos/jp/${system.theme}-w.png</path>
			<path>./../logos/jp/${system.theme}-w.svg</path>
			<path>./../logos/jp/${synonym}-w.png</path>
			<path>./../logos/jp/${synonym}-w.svg</path>
		</image>
	</view>
	<view name="system, menu">
<!-- Helpsystem bottom bar bg -->
		<image name="BottomBar" extra="static">
			<color>000000B9</color>
		</image>
	</view>
</theme>