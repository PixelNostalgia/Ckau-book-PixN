<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<!-- <include>./../../_inc/systemviews/animate.xml</include> -->
	<!-- Turns off all animated elements -->
	<view name="system">
		<text name="TextDate">
			<visible>false</visible>
		</text>
		<text name="TextManufacturer">
			<visible>false</visible>
		</text>
		<text name="TextName">
			<visible>false</visible>
		</text>
		<text name="TextDesc">
			<visible>false</visible>
		</text>
		<text name="TextVariant">
			<visible>false</visible>
		</text>
	<!-- Disable video -->
		<video name="videobox" extra="true">
			<visible>false</visible>
		</video>
	</view>
</theme>