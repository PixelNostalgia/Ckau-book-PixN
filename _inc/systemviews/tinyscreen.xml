<?xml version="1.0" encoding="UTF-8"?>
<theme>
  <formatVersion>7</formatVersion>
<!-- Меню / Menu -->
	<view name="menu">
		<menuText name="menutitle">
			<fontSize>0.04</fontSize>
		</menuText>
		<menuText name="menufooter">
			<fontSize>0.03</fontSize>
		</menuText>
		<menuText name="menutext" extra="true">
			<fontSize>0.045</fontSize>
		</menuText>
		<menuTextSmall name="menutextsmall" extra="true">
			<fontSize>0.04</fontSize>
		</menuTextSmall>
		<menuGroup name="menugroup">
			<fontSize>0.04</fontSize>
		</menuGroup>
	</view>

<!-- Clock, gamepad icons, battery indicator -->
	<view name="screen">
		<text name="clock">
			<fontSize>0.034</fontSize>
			<pos>0.888 0.945</pos>
			<size>0.1 0.058</size>
		</text>
		<controllerActivity name="controllerActivity">
			<!-- <visible if="${controllerActivity} < 2">false</visible> -->
			<pos>0.01 0.01</pos>
			<size>0.58 0.0475</size>
			<itemSpacing>0.012</itemSpacing>
		</controllerActivity>
		<!-- <batteryIndicator name="batteryIndicator">
			<size>0.058 0.0775</size>
		</batteryIndicator> -->
		<stackpanel name="batteryIndicatorNew" extra="true">
			<pos>0.4125 0.005</pos>
			<size>0.58 0.0575</size>
		</stackpanel>
	</view>
	<view name="system">
		<text name="systemInfo" extra="static">
			<color>FFFFFF</color>
			<pos>0.688 0.895</pos>
			<pos if="${global.clock} == 'false'">0.688 0.895</pos>
			<size>0.30 0.058</size>
			<fontSize>0.034</fontSize>
		</text>
	</view>
	
	<view name="system, menu, basic, detailed, grid, gamecarousel">
		<helpsystem name="help">
			<fontSize>0.034</fontSize>
			<origin>0 0.5</origin>
			<pos>0.012 0.975</pos>
		</helpsystem>
	</view>

<!-- Gamelist views -->
	<view name="detailed">
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</view>
	<view name="grid">
		<imagegrid name="gamegrid">
			<margin>0.005 0.014</margin>
			<autoLayout>3 1</autoLayout>
			<autoLayout if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">3 2</autoLayout>
		</imagegrid>
		
	</view>
	<view name="gamecarousel">
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</view>
	<customView name="Grid + Details">
		<imagegrid name="gamegrid">
			<autoLayout>2 1</autoLayout>
			<autoLayout if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">2 2</autoLayout>
		</imagegrid>
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</customView>
	<!-- <customView name="Grid + Details + Marquee" inherits="Grid + Details">
		<imagegrid name="gamegrid">
			<autoLayout>3 2</autoLayout>
		</imagegrid>
	</customView> -->
	<customView name="Grid + Fanart">
		<imagegrid name="gamegrid">
			<autoLayout>5 1</autoLayout>
			<autoLayout if="{system.theme} == 'snes' || {system.theme} == 'n64' || {system.theme} == 'gameandwatch' || {system.theme} == 'solarus' || {system.theme} == 'ngage'">3 1</autoLayout>
		</imagegrid>
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</customView>
	<!-- <customView name="Modern Grid">
		<imagegrid name="gamegrid">
			<autoLayout>5 1</autoLayout>
		</imagegrid>
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</customView> -->
	<!-- <customView name="Logo + Details">
		<imagegrid name="gamegrid">
			<autoLayout>3 3</autoLayout>
		</imagegrid>
	</customView> -->
	<customView name="Carousel">
		<stackpanel name="stackpanel-icons">
			<pos>0.04 0.80</pos>
			<size>0.9 0.046</size>
		</stackpanel>
		<stackpanel name="2st-line">
			<pos>0.04 0.85</pos>
			<size>0.9 0.046</size>
		</stackpanel>
		<stackpanel name="3st-line">
			<pos>0.04 0.90</pos>
			<size>0.9 0.046</size>
		</stackpanel>
	</customView>
	<customView name="Carousel + Details">
		<stackpanel name="stackpanel-icons">
			<pos>0.04 0.80</pos>
			<size>0.62 0.046</size>
		</stackpanel>
		<stackpanel name="2st-line">
			<pos>0.04 0.85</pos>
			<size>0.62 0.046</size>
		</stackpanel>
		<stackpanel name="3st-line">
			<pos>0.04 0.90</pos>
			<size>0.62 0.046</size>
		</stackpanel>
	</customView>
	<!-- <customView name="Carousel + Details + Marquee">
		<imagegrid name="gamegrid">
			<autoLayout>1 1</autoLayout>
		</imagegrid>
		<text name="md_description">
			<fontSize>0.035</fontSize>
		</text>
	</customView> -->
	<customView name="Carousel + Fanart">
		<stackpanel name="container-icons2">
			<pos>0.065 0.214</pos>
			<size>0.54 0.046</size>
		</stackpanel>
		<stackpanel name="game-data">
			<pos>0.065 0.43</pos>
			<size>0.54 0.046</size>
		</stackpanel>
		<text name="md_description">
			<pos>0.065 0.267</pos>
			<size>0.54 0.16</size>
		</text>
		<video name="md_video">
			<pos>0.785 0.433</pos>
		</video>
	</customView>
	<customView name="Tiles">
		<imagegrid name="gamegrid">
			<autoLayout>3 2</autoLayout>
		</imagegrid>
		<image name="gridtile.marquee">
			<size>0.80 0.80</size>
		</image>
		<image name="gridtile.marquee:selected">
			<size>0.95 0.95</size>
		</image>
	</customView>
	<!-- <customView name="Tiles + Video">
		<imagegrid name="gamegrid">
			<autoLayout>3 2</autoLayout>
		</imagegrid>
		<image name="gridtile.marquee">
			<size>0.80 0.80</size>
		</image>
		<image name="gridtile.marquee:selected">
			<size>0.95 0.95</size>
		</image>
	</customView> -->
	<customView name="Icons">
		<imagegrid name="gamegrid">
			<autoLayout>3 1</autoLayout>
		</imagegrid>
	</customView>
