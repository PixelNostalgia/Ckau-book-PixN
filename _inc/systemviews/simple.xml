<?xml version="1.0" encoding="UTF-8"?>
<theme>
	<formatVersion>7</formatVersion>
	<view name="system">
		<carousel name="systemcarousel">
			<type>vertical_wheel</type>
			<pos>0 -0.12</pos>
			<size>0.2 0.4</size>
			<origin>0 0</origin>
			<logoScale>1.2</logoScale>
			<logoSize>0.15 0.11</logoSize>
			<logoAlignment>center</logoAlignment>
			<maxLogoCount>7</maxLogoCount>
			<zIndex>75</zIndex>
			<!-- 4:3 -->
			<logoScale if="${screen.ratio} == '4/3'">1.8</logoScale>
			<itemTemplate>
				<container>
					<!-- <image name="logoDropShadow" pos="0.5" origin="0.5" maxSize="1" linearSmooth="true">
						<path>{system:logo}</path>
						<padding>4 4 -4 -4</padding>
						<color>00000050</color>
						<zIndex>1</zIndex>
					</image> -->
					<image name="LogoImage" pos="0.5" origin="0.5" maxSize="1" linearSmooth="false">
						<path>{system:logo}</path>
						<zIndex>2</zIndex>
					</image>
					<text name="substitutionText" color="white" alignment="center" multiLine="true">
						<visible>!exists({system:logo})</visible>
						<text>{system:fullName}</text>
						<fontSize>0.06</fontSize>
						<fontPath>${fontNameBold}</fontPath>
						<forceUppercase>false</forceUppercase>
						<color>white</color>
						<glowColor>00000010</glowColor>
						<glowSize>3</glowSize>
					</text>
					<storyboard event="activate">
						<animation property="opacity" to="1" duration="150" mode="Linear"/>
					</storyboard>
					<storyboard event="scroll">
						<animation property="opacity" to="0" duration="0" mode="Linear"/>
					</storyboard>
					<storyboard event="deactivate">
						<animation property="opacity" to="0" duration="0" mode="Linear"/>
					</storyboard>
				</container>
			</itemTemplate>
		</carousel>
		<!-- <image name="logo">
			<linearSmooth>true</linearSmooth>
				<storyboard event="activate">
				<animation property="opacity" from="0" to="1" duration="150" mode="Linear"/>
				<animation property="opacity" from="1" to="1" begin="1150" duration="35" mode="Linear"/>
				</storyboard>
				<storyboard event="scroll">
				<animation property="opacity" from="0" to="0" begin="0" duration="0" mode="Linear"/>
				</storyboard>
				<storyboard event="deactivate">
				<animation property="opacity" from="0" to="0" begin="0" duration="0" mode="Linear"/>
				</storyboard>
		</image> -->
	</view>
</theme>