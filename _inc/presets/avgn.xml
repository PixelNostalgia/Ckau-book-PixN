<?xml version="1.0" encoding="UTF-8"?>
<theme defaultView="Grid + Fanart">
	<formatVersion>7</formatVersion>
	<view name="grid">
		<imagegrid name="gamegrid">
			<autoLayout>6 2</autoLayout>
			<autoLayout if="${screen.ratio} == '21/9'">8 2</autoLayout>
		</imagegrid>
	</view>
	<customView name="Grid + Fanart">
		<image name="md_marquee">
			<maxSize>0.25 0.20</maxSize>
		</image>
		<image name="background" extra="true">
			<storyboard event="activate">
				<animation property="opacity" to="0.94" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="400" begin="4400" duration="0" mode="easeOut"/>
			</storyboard>
		</image>
		<imagegrid name="gamegrid">
			<autoLayout>6 3</autoLayout>
			<autoLayout if="${screen.ratio} == '21/9'">8 2</autoLayout>
			<padding>0.03 0.04 0.03 0.1</padding>
		</imagegrid>
		<video name="md_video">
			<delay>0.3</delay>
			<showSnapshotNoVideo>false</showSnapshotNoVideo>
			<showSnapshotDelay>false</showSnapshotDelay>
			<storyboard event="activateNext">
				<animation property="maxSize" to="0.98 0.98" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="pos" to="0.5 0.49" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="origin" to="0.5 0.5" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="1470" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
			<storyboard event="activatePrev">
				<animation property="maxSize" to="0.98 0.98" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="pos" to="0.5 0.49" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="origin" to="0.5 0.5" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="1470" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
		</video>
	</customView>
	<customView name="Grid + Details">
		<imagegrid name="gamegrid">
			<autoLayout>3 3</autoLayout>
			<autoLayout if="${screen.ratio} == '21/9'">5 2</autoLayout>
		</imagegrid>
		<image name="background" extra="true">
			<storyboard event="activate">
				<animation property="opacity" to="0.94" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="400" begin="4400" duration="0" mode="easeOut"/>
			</storyboard>
		</image>
		<video name="md_video">
			<delay>0.3</delay>
			<showSnapshotNoVideo>false</showSnapshotNoVideo>
			<showSnapshotDelay>false</showSnapshotDelay>
			<storyboard event="activateNext">
				<animation property="maxSize" to="0.98 0.98" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="pos" to="0.5 0.49" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="origin" to="0.5 0.5" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="1470" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
			<storyboard event="activatePrev">
				<animation property="maxSize" to="0.98 0.98" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="pos" to="0.5 0.49" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="origin" to="0.5 0.5" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="zIndex" to="1470" begin="3200" duration="1200" mode="EaseInQuint"/>
				<animation property="opacity" from="0" to="0" begin="0" duration="1" mode="linear"/>
				<animation property="opacity" from="0" to="1" begin="600" duration="300" mode="linear"/>
			</storyboard>
		</video>
	</customView>
</theme>